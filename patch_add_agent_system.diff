+from __future__ import annotations
+
+import os, json, uuid, hashlib
+from pathlib import Path
+from typing import List, Optional, Dict, Any, Iterable
+from datetime import datetime, timezone
+from pydantic import ValidationError
+
+from app.models.agent import (
+    Agent, AgentCreateRequest, AgentUpdateRequest,
+    TeachRequest, MemoryRecord
+)
+
+_DATA_DIR = Path(os.getenv("ROUTER_DATA_DIR", "/mnt/data/router_data")).resolve()
+_AGENTS_PATH = _DATA_DIR / "agents.json"
+_MEM_DIR = _DATA_DIR / "memories"
+
+def _utcnow() -> datetime:
+    return datetime.now(timezone.utc)
+
+def _load_agents() -> List[Dict[str, Any]]:
+    if not _AGENTS_PATH.exists():
+        return []
+    try:
+        with _AGENTS_PATH.open("r", encoding="utf-8") as f:
+            return json.load(f)
+    except Exception:
+        return []
+
+def _save_agents(rows: List[Dict[str, Any]]) -> None:
+    _DATA_DIR.mkdir(parents=True, exist_ok=True)
+    tmp = _AGENTS_PATH.with_suffix(".tmp")
+    with tmp.open("w", encoding="utf-8") as f:
+        json.dump(rows, f, ensure_ascii=False, indent=2, default=str)
+    tmp.replace(_AGENTS_PATH)
+
+def _validate_tools(tools: Optional[List[str]]) -> List[str]:
+    if not tools:
+        return []
+    available = set()
+    try:
+        from app.tools import registry as tools_registry  # type: ignore
+        reg = getattr(tools_registry, "REGISTRY", None)
+        if reg is None:
+            get_reg = getattr(tools_registry, "get_registry", None)
+            reg = get_reg() if callable(get_reg) else {}
+        if isinstance(reg, dict):
+            available = set(reg.keys())
+        elif isinstance(reg, Iterable):
+            available = set([getattr(x, "key", None) for x in reg if getattr(x, "key", None)])
+    except Exception:
+        available = set()
+    if available:
+        return [t for t in tools if t in available]
+    return list(tools)
+
+def list_agents(include_archived: bool = False) -> List[Agent]:
+    rows = _load_agents()
+    out: List[Agent] = []
+    for r in rows:
+        if not include_archived and r.get("status") == "archived":
+            continue
+        try:
+            out.append(Agent(**r))
+        except ValidationError:
+            continue
+    return out
+
+def _find_index(rows: List[Dict[str, Any]], agent_id: str) -> int:
+    for i, r in enumerate(rows):
+        if r.get("id") == agent_id:
+            return i
+    return -1
+
+def get_agent(agent_id: str) -> Optional[Agent]:
+    rows = _load_agents()
+    for r in rows:
+        if r.get("id") == agent_id:
+            try:
+                return Agent(**r)
+            except ValidationError:
+                return None
+    return None
+
+def create_agent(req: AgentCreateRequest) -> Agent:
+    rows = _load_agents()
+    for r in rows:
+        if r.get("name") == req.name and r.get("status") != "archived":
+            raise ValueError("Agent with this name already exists")
+    now = _utcnow()
+    agent = Agent(
+        id=f"agent_{uuid.uuid4().hex[:8]}",
+        name=req.name,
+        description=req.description,
+        emoji=req.emoji,
+        visibility=req.visibility,
+        teachable=req.teachable,
+        tools_allowed=_validate_tools(req.tools_allowed),
+        status="active",
+        created_at=now,
+        updated_at=now,
+    )
+    rows.append(agent.model_dump(mode="json"))
+    _save_agents(rows)
+    return agent
+
+def update_agent(agent_id: str, req: AgentUpdateRequest) -> Optional[Agent]:
+    rows = _load_agents()
+    idx = _find_index(rows, agent_id)
+    if idx == -1:
+        return None
+    row = rows[idx]
+    for field in ["name", "description", "emoji", "visibility", "teachable", "status"]:
+        val = getattr(req, field, None)
+        if val is not None:
+            row[field] = val
+    if req.tools_allowed is not None:
+        row["tools_allowed"] = _validate_tools(req.tools_allowed)
+    row["updated_at"] = _utcnow().isoformat()
+    _save_agents(rows)
+    try:
+        return Agent(**row)
+    except ValidationError:
+        return None
+
+def archive_agent(agent_id: str) -> bool:
+    rows = _load_agents()
+    idx = _find_index(rows, agent_id)
+    if idx == -1:
+        return False
+    rows[idx]["status"] = "archived"
+    rows[idx]["updated_at"] = _utcnow().isoformat()
+    _save_agents(rows)
+    return True
+
+def _mem_path(agent_id: str, scope: str, user_id: Optional[str]):
+    if scope == "per_user":
+        if not user_id:
+            raise ValueError("user_id required for per_user scope")
+        d = _MEM_DIR / agent_id / "per_user"
+        d.mkdir(parents=True, exist_ok=True)
+        return d / f"{user_id}.jsonl"
+    else:
+        d = _MEM_DIR / agent_id
+        d.mkdir(parents=True, exist_ok=True)
+        return d / "shared.jsonl"
+
+def teach(agent_id: str, req: TeachRequest) -> MemoryRecord:
+    ag = get_agent(agent_id)
+    if not ag:
+        raise ValueError("Agent not found")
+    rec = MemoryRecord(
+        memory_id=hashlib.sha1((req.content + (req.user_id or '')).encode('utf-8')).hexdigest()[:12],
+        scope=req.scope,
+        user_id=req.user_id,
+        tags=req.tags or [],
+        content=req.content,
+        created_at=_utcnow()
+    )
+    path = _mem_path(agent_id, req.scope, req.user_id)
+    line = json.dumps(rec.model_dump(mode="json"), ensure_ascii=False)
+    with open(path, "a", encoding="utf-8") as f:
+        f.write(line + "\n")
+    return rec
+
+def read_brain(agent_id: str, scope: Optional[str] = None, user_id: Optional[str] = None,
+               tag: Optional[str] = None, limit: int = 100):
+    ag = get_agent(agent_id)
+    if not ag:
+        return []
+    records = []
+    paths = []
+    if scope in (None, "shared"):
+        paths.append(_mem_path(agent_id, "shared", None))
+    if scope in (None, "per_user"):
+        per_dir = _MEM_DIR / agent_id / "per_user"
+        if user_id:
+            paths.append(_mem_path(agent_id, "per_user", user_id))
+        elif per_dir.exists():
+            paths.extend(per_dir.glob("*.jsonl"))
+    for p in paths:
+        if not p.exists():
+            continue
+        try:
+            with open(p, "r", encoding="utf-8") as f:
+                for line in f:
+                    try:
+                        obj = json.loads(line)
+                        if tag and tag not in (obj.get("tags") or []):
+                            continue
+                        records.append(MemoryRecord(**obj))
+                        if len(records) >= limit:
+                            return records
+                    except Exception:
+                        continue
+        except Exception:
+            continue
+    return records
+
+def exec_tool(agent_id: str, tool_key: str, params: Dict[str, Any], context: Optional[Dict[str, Any]] = None) -> Dict[str, Any]:
+    ag = get_agent(agent_id)
+    if not ag:
+        return {"ok": False, "error": "agent_not_found"}
+    if tool_key not in (ag.tools_allowed or []):
+        return {"ok": False, "error": "tool_not_allowed"}
+    try:
+        from app.tools import runner as tools_runner  # type: ignore
+        if hasattr(tools_runner, "exec_tool"):
+            return tools_runner.exec_tool(agent_id=agent_id, key=tool_key, params=params, ctx=context or {})
+        if hasattr(tools_runner, "run"):
+            out = tools_runner.run(tool_key, params, context or {})
+            return {"ok": True, "output": out}
+        return {"ok": False, "error": "runner_missing_exec_tool"}
+    except Exception as e:
+        return {"ok": False, "error": f"runner_error: {e}"}
+
+def log_message(agent_id: str, content: str, user_id: Optional[str] = None, tag: str = "msg") -> MemoryRecord:
+    return teach(agent_id, TeachRequest(content=content, scope="shared", user_id=user_id, tags=[tag]))
